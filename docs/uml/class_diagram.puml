@startuml LibraryLMS_ClassDiagram
skinparam defaultTextAlignment left
skinparam style strictuml
skinparam backgroundColor White
skinparam handwritten false
skinparam monochrome true

skinparam class {
  BorderColor Black
  BackgroundColor White
  HeaderBackgroundColor White
  FontColor Black
  AttributeFontColor Black
  FontSize 11
  AttributeFontSize 10
  FontStyle plain
  BorderThickness 1
}

skinparam package {
  BorderColor Black
  BackgroundColor White
  FontColor Black
  FontSize 12
  FontStyle bold
  BorderThickness 1
}

skinparam arrow {
  Color Black
  FontColor Black
  FontSize 10
  Thickness 1
}

skinparam note {
  BackgroundColor White
  BorderColor Black
  FontSize 10
}

' ============================================================================
' PACKAGE: Data Layer — Database Models (Prisma ORM)
' ============================================================================
package "Data Layer — Database Models" as DB {

  class User << (D,white) >> {
    + id : Int
    + full_name : String
    + email : String
    - password_hash : String
    + role : String
    + is_active : Boolean
    + created_at : DateTime
    --
    + borrows : BorrowRecord[]
    + fines : Fine[]
    + wallet : Wallet?
    + reservations : Reservation[]
  }

  class Book << (D,white) >> {
    + id : Int
    + title : String
    + author : String
    + isbn : String
    + category : String
    + total_quantity : Int
    + available_quantity : Int
    + is_deleted : Boolean
    + reserved_for_user_id : Int?
    + reservation_expires_at : DateTime?
    + created_at : DateTime
    + updated_at : DateTime
    --
    + borrow_items : BorrowItem[]
    + metadata : BookMetadata?
    + reservations : Reservation[]
  }

  class BookMetadata << (D,white) >> {
    + id : Int
    + book_id : Int
    + cover_image_url : String?
    + description : String?
    + publisher : String?
    + publish_year : Int?
    + language : String?
    + subjects : String?
    + page_count : Int?
    + rating : Float?
    + source_url : String?
    + crawled_at : DateTime?
  }

  class BorrowRecord << (D,white) >> {
    + id : Int
    + user_id : Int
    + borrow_date : DateTime
    + due_date : DateTime
    + return_date : DateTime?
    + return_requested_at : DateTime?
    + confirmed_by : Int?
    + status : String
    + reminder_sent : Boolean
    + reminder_sent_at : DateTime?
    --
    + items : BorrowItem[]
    + fines : Fine[]
  }

  class BorrowItem << (D,white) >> {
    + id : Int
    + borrow_record_id : Int
    + book_id : Int
    + quantity : Int
  }

  class Fine << (D,white) >> {
    + id : Int
    + borrow_record_id : Int
    + user_id : Int
    + amount : Int
    + reason : String
    + is_paid : Boolean
    + paid_at : DateTime?
    + paid_by : Int?
    + payment_method : String?
    + overdue_days : Int?
    + created_at : DateTime
    --
    + payments : FinePayment[]
  }

  class Wallet << (D,white) >> {
    + id : Int
    + user_id : Int
    + balance : Int
    + created_at : DateTime
    + updated_at : DateTime
    --
    + transactions : WalletTransaction[]
    + fine_payments : FinePayment[]
  }

  class WalletTransaction << (D,white) >> {
    + id : Int
    + wallet_id : Int
    + amount : Int
    + balance_before : Int?
    + balance_after : Int?
    + type : String
    + status : String
    + payment_method : String?
    + reference : String?
    + description : String?
    + created_at : DateTime
  }

  class FinePayment << (D,white) >> {
    + id : Int
    + fine_id : Int
    + wallet_id : Int
    + amount : Int
    + created_at : DateTime
  }

  class Notification << (D,white) >> {
    + id : Int
    + user_id : Int
    + title : String
    + message : String
    + type : String
    + is_read : Boolean
    + reference : String?
    + created_at : DateTime
  }

  class Reservation << (D,white) >> {
    + id : Int
    + user_id : Int
    + book_id : Int
    + status : String
    + queue_position : Int?
    + reserved_at : DateTime
    + notified_at : DateTime?
    + expires_at : DateTime?
    + completed_at : DateTime?
    + cancelled_at : DateTime?
  }

  class CrawlLog << (D,white) >> {
    + id : Int
    + job_type : String
    + isbn : String?
    + status : String
    + source : String?
    + books_found : Int
    + books_updated : Int
    + error_msg : String?
    + started_at : DateTime
    + finished_at : DateTime?
  }
}

' ============================================================================
' PACKAGE: Configuration Layer
' ============================================================================
package "Configuration Layer" as CFG {

  class ENV {
    + NODE_ENV : String
    + PORT : Int
    + JWT_SECRET : String
    + CLIENT_URL : String
    + DATABASE_URL : String
    + GOOGLE_BOOKS_API_KEY : String
    + CRAWL_CONCURRENCY : Int
    + CRAWL_DELAY_MS : Int
  }

  class PrismaDB {
    + {static} prisma : PrismaClient
  }
}

' ============================================================================
' PACKAGE: Server — Controllers
' ============================================================================
package "Server — Controllers" as CTRL {

  class AuthController {
    + {static} register(req, res, next) : Promise
    + {static} login(req, res, next) : Promise
    + {static} getMe(req, res, next) : Promise
  }

  class BookController {
    + {static} list(req, res, next) : Promise
    + {static} getById(req, res, next) : Promise
    + {static} create(req, res, next) : Promise
    + {static} update(req, res, next) : Promise
    + {static} remove(req, res, next) : Promise
  }

  class BorrowController {
    + {static} create(req, res, next) : Promise
    + {static} selfBorrow(req, res, next) : Promise
    + {static} list(req, res, next) : Promise
    + {static} getById(req, res, next) : Promise
    + {static} listMy(req, res, next) : Promise
    + {static} requestReturn(req, res, next) : Promise
    + {static} confirmReturn(req, res, next) : Promise
  }

  class FineController {
    + {static} list(req, res, next) : Promise
    + {static} listMy(req, res, next) : Promise
    + {static} selfPay(req, res, next) : Promise
    + {static} revenue(req, res, next) : Promise
  }

  class DashboardController {
    + {static} summary(req, res, next) : Promise
    + {static} mySummary(req, res, next) : Promise
  }

  class UserController {
    + {static} list(req, res, next) : Promise
    + {static} create(req, res, next) : Promise
    + {static} update(req, res, next) : Promise
    + {static} toggleActive(req, res, next) : Promise
  }

  class WalletController {
    + {static} get(req, res, next) : Promise
    + {static} addCredits(req, res, next) : Promise
    + {static} transactions(req, res, next) : Promise
  }

  class CrawlController {
    + {static} enrichByIsbn(req, res, next) : Promise
    + {static} batchEnrich(req, res, next) : Promise
    + {static} getLogs(req, res, next) : Promise
    + {static} deleteLogs(req, res, next) : Promise
  }

  class ReservationController {
    + {static} create(req, res, next) : Promise
    + {static} listMy(req, res, next) : Promise
    + {static} listQueue(req, res, next) : Promise
    + {static} cancel(req, res, next) : Promise
    + {static} stats(req, res, next) : Promise
  }

  class NotificationController {
    + {static} list(req, res, next) : Promise
    + {static} unreadCount(req, res, next) : Promise
    + {static} markRead(req, res, next) : Promise
    + {static} markAllRead(req, res, next) : Promise
    + {static} remove(req, res, next) : Promise
  }
}

' ============================================================================
' PACKAGE: Server — Services (Business Logic)
' ============================================================================
package "Server — Services" as SVC {

  class AuthService {
    + {static} register(fullName, email, password) : Promise<User>
    + {static} login(email, password) : Promise<{token, user}>
    + {static} getMe(userId) : Promise<User>
  }

  class BookService {
    + {static} listBooks(search, page, limit, available, category) : Promise<PageResult>
    + {static} getBook(id) : Promise<Book>
    + {static} createBook(data) : Promise<Book>
    + {static} updateBook(id, data) : Promise<Book>
    + {static} softDeleteBook(id) : Promise<Book>
  }

  class BorrowService {
    + {static} createBorrow(userId, items) : Promise<BorrowRecord>
    + {static} listBorrows(status, page, limit) : Promise<PageResult>
    + {static} getBorrowById(id) : Promise<BorrowRecord>
    + {static} listMyBorrows(userId, status) : Promise<BorrowRecord[]>
    + {static} requestReturn(borrowId, userId) : Promise<BorrowRecord>
    + {static} confirmReturn(borrowId, librarianId) : Promise<BorrowRecord>
  }

  class FineService {
    + {static} listFines(isPaid, page, limit) : Promise<PageResult>
    + {static} listMyFines(userId, page, limit) : Promise<PageResult>
    + {static} selfPayFine(fineId, userId) : Promise<Fine>
    + {static} getRevenueSummary() : Promise<Object>
  }

  class DashboardService {
    + {static} getSummary() : Promise<Object>
    + {static} getMySummary(userId) : Promise<Object>
  }

  class UserService {
    + {static} listUsers(role, page, limit) : Promise<PageResult>
    + {static} createUser(data) : Promise<User>
    + {static} updateUser(id, data) : Promise<User>
    + {static} toggleActive(id) : Promise<User>
  }

  class WalletService {
    + {static} getOrCreateWallet(userId) : Promise<Wallet>
    + {static} getWallet(userId) : Promise<Wallet>
    + {static} addCredits(userId, amount, paymentMethod) : Promise<Wallet>
    + {static} deductFromWallet(userId, amount, reference, description) : Promise<Wallet>
    + {static} getTransactions(userId, page, limit) : Promise<Object>
  }

  class CrawlService {
    + {static} enrichByIsbn(isbn) : Promise<Object>
    + {static} batchEnrich() : Promise<Object>
    + {static} getLogs() : Promise<CrawlLog[]>
    + {static} deleteOldLogs() : Promise<Object>
  }

  class ReservationService {
    + {static} createReservation(userId, bookId) : Promise<Reservation>
    + {static} getMyReservations(userId) : Promise<Reservation[]>
    + {static} getQueueForBook(bookId) : Promise<Reservation[]>
    + {static} cancelReservation(reservationId, userId) : Promise<Object>
    + {static} processReturnAndPromoteQueue(bookId, tx) : Promise
    + {static} processExpiredReservations() : Promise<Int>
    + {static} getActiveReservationForUser(userId, bookId) : Promise<Reservation?>
    + {static} getReservationStats() : Promise<Object>
  }

  class NotificationService {
    + {static} createNotification(userId, title, message, type, reference) : Promise<Notification>
    + {static} listNotifications(userId, page, limit) : Promise<Object>
    + {static} markAsRead(notificationId, userId) : Promise<Notification>
    + {static} markAllAsRead(userId) : Promise
    + {static} getUnreadCount(userId) : Promise<Int>
    + {static} deleteNotification(notificationId, userId) : Promise
  }

  class SchedulerService {
    + {static} startScheduler() : void
  }
}

' ============================================================================
' PACKAGE: Server — Middlewares
' ============================================================================
package "Server — Middlewares" as MID {

  class AuthMiddleware {
    + {static} authMiddleware(req, res, next) : void
  }

  class ErrorHandler {
    + {static} errorHandler(err, req, res, _next) : void
  }

  class RoleGuard {
    + {static} roleGuard(...roles) : Function
  }
}

' ============================================================================
' PACKAGE: Server — Utilities
' ============================================================================
package "Server — Utilities" as UTIL {

  class FineCalculator {
    + {static} FINE_PER_DAY : Int = 2000
    + {static} calculateFine(dueDate, returnDate) : Int
  }

  class PaginateHelper {
    + {static} paginate(model, args, page, limit) : Promise<PageResult>
  }

  class ResponseHelper {
    + {static} success(res, data, message, statusCode) : Response
    + {static} error(res, message, statusCode, errors) : Response
  }
}

' ============================================================================
' PACKAGE: Server — External Crawlers
' ============================================================================
package "Server — Crawlers" as CWL {

  class CrawlerUtils {
    + {static} delay(ms) : Promise
    + {static} retryFetch(fn, retries, baseDelayMs) : Promise
    + {static} sanitizeText(raw) : String?
  }

  class GoogleBooksCrawler {
    + {static} fetchByIsbn(isbn) : Promise<Object?>
  }

  class OpenLibraryCrawler {
    + {static} fetchByIsbn(isbn) : Promise<Object?>
  }
}

' ============================================================================
' PACKAGE: Server — Routes & Validators
' ============================================================================
package "Server — Routes & Validators" as RTE {

  class AuthRoutes {
    + POST /api/auth/register
    + POST /api/auth/login
    + GET /api/auth/me
  }

  class BookRoutes {
    + GET /api/books
    + GET /api/books/:id
    + POST /api/books
    + PUT /api/books/:id
    + DELETE /api/books/:id
  }

  class BorrowRoutes {
    + POST /api/borrows
    + POST /api/borrows/self
    + GET /api/borrows/my
    + GET /api/borrows
    + GET /api/borrows/:id
    + POST /api/borrows/:id/request-return
    + PATCH /api/borrows/:id/confirm-return
  }

  class FineRoutes {
    + GET /api/fines/my
    + GET /api/fines/revenue
    + GET /api/fines
    + PATCH /api/fines/:id/self-pay
  }

  class UserRoutes {
    + GET /api/users
    + POST /api/users
    + PUT /api/users/:id
    + PATCH /api/users/:id/toggle-active
  }

  class WalletRoutes {
    + GET /api/wallet
    + POST /api/wallet/add
    + GET /api/wallet/transactions
  }

  class DashboardRoutes {
    + GET /api/dashboard/summary
    + GET /api/dashboard/my
  }

  class CrawlRoutes {
    + POST /api/crawl/isbn/:isbn
    + POST /api/crawl/batch
    + GET /api/crawl/logs
    + DELETE /api/crawl/logs
  }

  class ReservationRoutes {
    + POST /api/reservations
    + GET /api/reservations/my
    + GET /api/reservations/stats
    + GET /api/reservations/book/:bookId/queue
    + DELETE /api/reservations/:id
  }

  class NotificationRoutes {
    + GET /api/notifications
    + GET /api/notifications/unread-count
    + PATCH /api/notifications/:id/read
    + PATCH /api/notifications/read-all
    + DELETE /api/notifications/:id
  }

  class AuthValidator {
    + {static} registerValidation : ValidationChain[]
    + {static} loginValidation : ValidationChain[]
  }

  class BookValidator {
    + {static} createBookValidation : ValidationChain[]
    + {static} updateBookValidation : ValidationChain[]
  }

  class BorrowValidator {
    + {static} createBorrowValidation : ValidationChain[]
    + {static} returnBorrowValidation : ValidationChain[]
  }

  class UserValidator {
    + {static} createUserValidation : ValidationChain[]
    + {static} updateUserValidation : ValidationChain[]
  }
}

' ============================================================================
