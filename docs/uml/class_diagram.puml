  class AddCreditsModal {
    + onClose : Function
    + onSuccess : Function
    + render() : JSX.Element
  }

  class NotificationPanel {
    + render() : JSX.Element
  }

  class Pagination {
    + page : Int
    + pages : Int
    + total : Int
    + onPageChange : Function
    + loading : Boolean
    + render() : JSX.Element
  }
}

