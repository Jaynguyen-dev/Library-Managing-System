' ============================================================================
' RELATIONSHIPS — Database Model Associations
' ============================================================================
User "1" --> "0..*" BorrowRecord : borrows
User "1" --> "0..*" Fine : fines
User "1" --> "0..1" Wallet : wallet
User "1" --> "0..*" Reservation : reservations
User "1" --> "0..*" Notification : notifications

Book "1" --> "0..*" BorrowItem : borrow_items
Book "1" --> "0..1" BookMetadata : metadata
Book "1" --> "0..*" Reservation : reservations

BorrowRecord "1" --> "0..*" BorrowItem : items
BorrowRecord "1" --> "0..*" Fine : fines
BorrowRecord "*" --> "1" User : user

BorrowItem "*" --> "1" BorrowRecord : borrow_record
BorrowItem "*" --> "1" Book : book

Fine "*" --> "1" BorrowRecord : borrow_record
Fine "*" --> "1" User : user
Fine "1" --> "0..*" FinePayment : payments

Wallet "1" --> "0..*" WalletTransaction : transactions
Wallet "1" --> "0..*" FinePayment : fine_payments
Wallet "1" --> "1" User : user

WalletTransaction "*" --> "1" Wallet : wallet

FinePayment "*" --> "1" Fine : fine
FinePayment "*" --> "1" Wallet : wallet

Reservation "*" --> "1" User : user
Reservation "*" --> "1" Book : book

