---
title: LibraryLMS Business Function Diagram
---
flowchart TB
    classDef actor fill:#2563eb,color:#fff,stroke:#1d4ed8,stroke-width:2px
    classDef domain fill:#f8fafc,stroke:#64748b,stroke-width:2px
    classDef function fill:#eff6ff,stroke:#3b82f6,stroke-width:1px
    classDef sub fill:#f0fdf4,stroke:#22c55e,stroke-width:1px
    classDef flow fill:#fef2f2,stroke:#ef4444,stroke-width:2px
    classDef storage fill:#f5f3ff,stroke:#8b5cf6,stroke-width:2px

    subgraph Actors["External Actors"]
        Reader(("&#128100; Reader")):::actor
        Librarian(("&#128100; Librarian")):::actor
        Cron(("&#9200; System Scheduler")):::actor
    end

    subgraph Identity["1. Identity and Access Management"]
        direction TB
        A1[Register / Login]:::function
        A2[JWT Authentication]:::function
        A3[Role-Based Guard]:::function
        A4[Account Management]:::function
    end

    subgraph Catalog["2. Catalog Management"]
        direction TB
        C1[Book CRUD Operations]:::function
        C2[Search, Filter and Paginate]:::function
        C3[Category System]:::function
        C4[Inventory Tracking]:::function
        C5[Metadata Enrichment Crawler]:::function
    end

    subgraph Circulation["3. Circulation Management"]
        direction TB
        BR1[Multi-Book Checkout]:::function
        BR2[Return Request by Reader]:::function
        BR3[Return Confirmation by Librarian]:::function
        BR4[30-Day Loan Period]:::function
        BR5[Reservation Queue System]:::function
    end

    subgraph Financial["4. Financial Management"]
        direction TB
        W1[Digital Wallet]:::function
        W2[Top-Up via Payment Gateways]:::function
        W3[Fine Calculation 2000 VND/day]:::function
        W4[Fine Payment and Deduction]:::function
        W5[Transaction Audit Ledger]:::function
    end

    subgraph Insights["5. Insights and Communication"]
        direction TB
        D1[Librarian Analytics Dashboard]:::function
        D2[Reader Dashboard and Insights]:::function
        N1[Notification System]:::function
        N2[In-App Alerts and Reminders]:::function
    end

    subgraph Scheduler["6. Background Automation"]
        direction TB
        S1[Daily Due-Soon Reminders 8AM]:::function
        S2[Midnight Overdue Processing]:::function
        S3[Auto-Deduct Wallet Fines 2:30AM]:::function
        S4[Reservation Expiry Checker 30min]:::function
    end

    subgraph Storage["Core Data Entities"]
        DB1[(Users and Roles)]:::storage
        DB2[(Books and Metadata)]:::storage
        DB3[(Borrow Records, Items)]:::storage
        DB4[(Wallets, Transactions, Fines)]:::storage
        DB5[(Reservations, Notifications)]:::storage
    end

