%%{init: {"theme": "base", "themeVariables": { "fontSize": "28px", "fontFamily": "Arial", "primaryColor": "#f3ebff", "primaryBorderColor": "#9a76d4", "primaryTextColor": "#333333", "lineColor": "#333333"}}}%%
flowchart TD
    Admin(["👤 Thủ thư"]) --> API["POST /api/borrows"]
    
    API --> CheckUser["1. Kiểm tra User tồn tại & active"]
    CheckUser -- "Lỗi" --> ErrUser["❌ Lỗi User"]
    
    CheckUser -- "Hợp lệ" --> CheckBook["2. Kiểm tra Sách tồn tại"]
    CheckBook -- "Lỗi" --> ErrBook["❌ Lỗi Sách"]
    
    CheckBook -- "Hợp lệ" --> TxStart["🔒 Bắt đầu Giao dịch (Transaction)"]
    
    TxStart --> CheckQty
    
    subgraph TX ["Khối Giao dịch (Serializable)"]
        direction TB
        CheckQty["3. Kiểm tra số lượng (available >= quantity)"]
        
        CheckQty -- "Thiếu sách" --> ErrQty["❌ Lỗi: Không đủ sách"]
        
        CheckQty -- "Đủ sách" --> Execute["4. Thực thi Ghi dữ liệu đồng loạt:<br/>- Tạo BorrowRecord & BorrowItem (INSERT)<br/>- Trừ số lượng available_quantity (UPDATE)<br/>- Xử lý quyền Đặt trước (Xóa / Đánh dấu hoàn thành)"]
    end
    
    Execute --> Success["✅ Commit Transaction &<br/>Trả về kết quả Mượn thành công"]
    
    style TX fill:#fdf8e2,stroke:#f1c40f,stroke-width:2px,color:#333;
